# 根拠 — 環境変数

# Database (Neon)
DATABASE_URL=""   # pooled connection string
DIRECT_URL=""     # direct connection (prisma migrate/push用)

# Auth.js（本番は www 付きで統一。factbase.tokyo は www へリダイレクトされる）
# Google Console のリダイレクト URI: https://www.factbase.tokyo/auth/callback/google
AUTH_SECRET=""    # openssl rand -hex 32
AUTH_URL="https://www.factbase.tokyo"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_TWITTER_ID=""
AUTH_TWITTER_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_COMMENT=""    # ¥500/月 price id
STRIPE_PRICE_FACTCHECK=""  # ¥980/月 price id

# AI — 門番（FC / claims検証 / 選別 / embedding）: Azure OpenAI
OPENAI_API_KEY=""      # OpenAI or Azure OpenAI API key
OPENAI_BASE_URL=""     # Azure OpenAI: https://<resource>.openai.azure.com/openai/v1
# Optional aliases if you prefer Azure-specific names
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_BASE_URL=""

# AI — 記事主筆（GPT-5.6 Luna に換装）
# 優先1: Azure AI Foundry にデプロイした場合（推奨）
ARTICLE_API_KEY=""     # 省略時は OPENAI_/AZURE_ を流用
ARTICLE_BASE_URL=""    # 例: https://<resource>.services.ai.azure.com（/models は自動付与）
ARTICLE_MODEL=""       # Foundry のデプロイ名。例: gpt-5.6-luna（省略時 AI_MODELS.article）
# 優先2: xAI 直（任意）
XAI_API_KEY=""
XAI_BASE_URL=""        # 省略時 https://api.x.ai/v1

# Upstash Redis（未設定時はin-memoryフォールバック＝開発専用）
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# 地理制限（本番は日本国内のみ。開発では自動で緩和。海外テスト時のみ true）
GEO_ALLOW_ALL=""

# 管理ダッシュボード（/admin）— カンマ区切りの管理者メール
ADMIN_EMAILS=""

# YouTube Data API（Radarバズ検知。未設定時はYouTubeソースのみスキップ）
YOUTUBE_DATA_API_KEY=""

# e-Stat政府統計API（経済系トピックで数値一次情報を記事に補足。無料登録で取得）
# 登録: https://www.e-stat.go.jp/api/ → API機能利用申請 → appId を設定
# 未設定時はe-Stat参照をスキップし他の材料で続行（記事生成は継続される）
ESTAT_APP_ID=""

# Radar内部API（scripts/radar/*.ts → /api/internal/radar-revalidate の認証）
# 未設定でもRadarは動くが、revalidate通知がスキップされ反映まで最大1時間かかる
RADAR_INTERNAL_SECRET=""    # openssl rand -hex 32

# 管理ダッシュボードからGitHub Actions（Radar）の実行状況確認・手動実行を行うためのトークン。
# 未設定でも/adminの他機能は動く（このパネルだけ「未設定」表示になる）。
# 発行方法: GitHub → Settings → Developer settings → Fine-grained tokens
#   対象リポジトリ: このリポジトリのみ / Permissions: Actions = Read and write
GITHUB_TOKEN=""
