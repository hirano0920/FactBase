generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum Plan {
  FREE
  COMMENT
  FACTCHECK
}

enum VoteChoice {
  FOR
  AGAINST
  UNDECIDED
}

enum IssueStatus {
  ACTIVE
  TRENDING
  PASSED
  ARCHIVED
}

enum IssueCategory {
  POLITICS
  LAW
  ECONOMY
  FINANCE
  EDUCATION
  SOCIETY
  ENTERTAINMENT
}

enum FcVerdict {
  TRUE // 一次情報で確認できた
  FALSE // 一次情報と矛盾
  UNKNOWN // 一次情報では確認不可
  OPINION // 意見・評価
  REPORTED // 報道の存在は確認・内容の真偽は未確認
  DISPUTED // 当事者間で主張が対立 / 解釈が分かれる
}

enum ModerationStatus {
  VISIBLE // 通常表示
  AUTO_HIDDEN // 通報閾値到達で一時非表示（AI判定待ち）
  AI_CLEARED // AIが問題なしと判定し復帰（再度の自動非表示はしない）
  REMOVED_AI // AIが違反と高確度判定（異議申立可）
  REMOVED_HUMAN // 人間が削除確定
  HUMAN_REVIEW // AIが判定を保留し人間キュー行き（非表示のまま）
}

enum RadarStatus {
  PENDING // 検知直後
  PUBLISHED // 自動公開済み
  HELD // 安全ゲートで下書き止め（人間確認必須）
  REJECTED // スコア不足で見送り
}

enum ConfirmationStatus {
  OFFICIAL // 公式発表・法案・判決・統計ベース
  REPORTED // 報道ベース / 真偽未確認
  MANUAL // 手動作成（従来の法令争点）
}

/** TwoSides のプロダクトトラック。debateType（policy等）とは別軸。 */
enum IssueTrack {
  DEBATE // スプリットスレッド議論向け（両側論点あり）
  NEWS // ホット話題のタイパまとめ（両側強制なし）
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  // 軽量プロフィール: 一言自己紹介・絵文字アバター（画像アップロードは不要な設計）
  bio                    String?
  avatarEmoji            String?
  plan                   Plan      @default(FREE)
  planUntil              DateTime?
  // Stripe: 二重課金防止・解約導線・webhookのユーザー解決に必須
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  // 新規登録時のIP/国（90日1IP1アカウント・不正投票対策）
  registrationIp         String?
  registrationCountry    String?
  // サイト内続報通知バッジ（ブックマーク/投票した争点の更新）の既読カーソル。
  // nullなら「一度も確認したことがない」＝createdAt以降の全更新を未読として扱う
  notificationsCheckedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  votes          Vote[]
  voteEvents     VoteEvent[]
  comments       Comment[]
  badges         UserBadge[]
  reports        Report[]
  bookmarks      Bookmark[]
  qualityReports IssueQualityReport[]
  appeals        Appeal[]

  @@index([registrationIp, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Issue {
  id                 String        @id @default(cuid())
  slug               String        @unique
  title              String
  // X/SEO用の「自分ごとフック」タイトル（composeIssueTitle生成）。titleは中立な投票設問のまま維持し、
  // OG/メタタイトルだけ引きの強い表現にする（2層タイトル分離）。未設定時はtitleにフォールバック
  shareTitle         String?
  category           IssueCategory
  status             IssueStatus   @default(ACTIVE)
  summaryJson        Json
  articleHtml        String?
  articleGeneratedAt DateTime?
  monitoringUntil    DateTime?
  keywords           String[]
  // 非正規化カウンタ: Redisが真実のソース、DBは非同期追従（一覧・SEOページ用）
  voteForCount       Int           @default(0)
  voteAgainstCount   Int           @default(0)
  voteUndecidedCount Int           @default(0)
  commentCount       Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Radar由来の争点用メタデータ
  confirmation   ConfirmationStatus   @default(MANUAL)
  voteLabelsJson Json? // 投票ボタンのカスタム文言 {"for":"説明すべき","against":"問題ない","undecided":"判断できない"}
  // TwoSides争点タイプ（declaration/policy/org_response/norm_flare/indicator/geopolitics）。
  // 生成時（resolveDebateType）は使っていたが、これまでIssueレコードには残しておらず、
  // 公開後にレスバ支援AI等が争点タイプ別の切り口を再利用できなかった。null=旧データ/推定不能
  debateType     String?
  // プロダクトトラック。DEBATE=両側議論 / NEWS=ホット話題まとめ。旧データはDEBATE扱い。
  track          IssueTrack @default(DEBATE)
  // カード用サムネイル。自前保存はせず出典URLの画像をリンクプレビューとして直接参照するだけ
  // （転載・再配布はしない）。取得できなかった/拒否された場合は全てnullのままフォールバック表示。
  thumbnailUrl       String?
  thumbnailSourceUrl String? // 出典明記・クリックで元記事に飛べるようにする
  thumbnailSourceFeed String? // カード上の出典表記（媒体名）
  // 要点カード中の難語ポップオーバー用語集。[{"term","matchText","def","source":"wikipedia"|"ai","wikipediaUrl"}]
  // 生成時（composeGlossary）に一度だけ作る。null=旧記事（未生成）
  glossaryJson Json?
  // 公開後の品質報告（誤った要約・的外れなスレ立て等）が閾値に達すると true。
  // 人間確認が終わるまでトレンド表示・新規流入から外す（削除はしない＝透明性ログとして残す）
  underReview    Boolean              @default(false)
  qualityReports IssueQualityReport[]
  // 常設debate（長年論争になってる争点）。オーナーが手動で選定・trueにする運用が前提で、
  // discover/promoteの自動パイプラインからは付与しない。
  isStanding     Boolean              @default(false)

  votes         Vote[]
  voteEvents    VoteEvent[]
  comments      Comment[]
  evidenceLinks IssueEvidenceLink[]
  timeline      IssueTimeline[]
  bookmarks     Bookmark[]
  sourceEvents  SourceEvent[]
  politicians   IssuePolitician[]
}

// 「この要約はおかしい」報告（Radar自動生成争点向け）。閾値到達でunderReview化。
model IssueQualityReport {
  id         String   @id @default(cuid())
  issueId    String
  reporterId String
  reason     String?
  createdAt  DateTime @default(now())

  issue    Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  reporter User  @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([issueId, reporterId])
}

// Radarが検知した生シグナル（30日でクリーンアップ・Layer 2）
model SourceEvent {
  id          String   @id @default(cuid())
  feedName    String
  trustWeight Int // フィード信頼度 20-100
  title       String
  url         String
  publishedAt DateTime
  hash        String   @unique // feedName+titleのsha256（重複取り込み防止）
  createdAt   DateTime @default(now())
  // 公開済みIssueの続報だとnano/AIが判定した場合にセット（続報自動追記・記事再生成の起点）
  issueId     String?

  issue Issue? @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([issueId])
}

// Radarのトピック候補と公開判断ログ（透明性レポートの材料・長期保存）
model TopicCandidate {
  id              String      @id @default(cuid())
  dedupKey        String      @unique // 正規化タイトル（同一トピックの再検知防止）
  title           String
  category        String? // politics/economy/law/finance/rights/international
  classification  String? // official/report/scandal/incident/indicator
  eventCount      Int         @default(0)
  distinctFeeds   Int         @default(0)
  hotScore        Int         @default(0)
  trustScore      Int         @default(0)
  riskScore       Int         @default(0)
  riskFlags       String[] // 検出された危険シグナル
  decision        String? // 判断式の内訳（監査用）
  status          RadarStatus @default(PENDING)
  sourceUrls      Json // [{"title","url","feed"}]
  issueId         String?     @unique
  // 能動調査パイプライン（discover.ts）由来の候補メタデータ。
  // 従来のRSSクラスタ由来候補は discoverySource=null のまま。
  discoverySource String? // "buzz" | "bill" | "rss"
  topicTerm       String? // 正規化トピック語（証拠再取得・続報照合キー）
  evidenceJson    Json? // 能動調査の証拠バンドル（国会会議録・法令・関連ニュース）
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([discoverySource, createdAt])
}

// 争点の時系列更新（続報・本人反応・訂正）
model IssueTimeline {
  id        String   @id @default(cuid())
  issueId   String
  label     String // 「速報スレ公開」「Sonnetまとめ公開」「本人が否定を表明」等
  sourceUrl String?
  at        DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, at])
}

// Google Trends/Yahoo!リアルタイム検索の出現履歴を自前で蓄積し、
// 「1回だけ出た瞬間バズ」と「何時間も出続けている継続的な話題」を区別するための定点観測テーブル。
// detect.ts が cron 実行のたびに upsert し、sightingCount と firstSeenAt〜lastSeenAt の幅で判定する。
model TrendSighting {
  id            String   @id @default(cuid())
  term          String
  source        String // "google_trends" | "yahoo_realtime"
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  sightingCount Int      @default(1)

  @@unique([term, source])
  @@index([lastSeenAt])
}

// Tavily発見結果のドメイン信頼度フィルタの運用管理版。
// scripts/radar/lib/domain-trust.ts のハードコードdenylist（コード変更・デプロイが必須）を補完し、
// 運用中に見つかった低品質ドメインを管理画面からデプロイ無しで追加・削除できるようにする。
model DomainTrustRule {
  id        String   @id @default(cuid())
  hostname  String   @unique // 例: "example.com"（そのホスト名またはサブドメインをTavily採用対象から除外）
  action    String   @default("DENY") // 現状はDENYのみ運用（将来の拡張余地として文字列管理）
  note      String?
  createdAt DateTime @default(now())

  @@index([action])
}

// モデレーション人間キュー（AIが判定保留した1割 + 異議申立）
model ModerationCase {
  id         String    @id @default(cuid())
  commentId  String
  source     String // "reports"(通報起点) | "appeal"(異議申立)
  aiVerdict  Json? // nanoの判定内容（人間の参考情報）
  status     String    @default("PENDING") // PENDING | RESOLVED
  resolution String? // "removed" | "restored" | "appeal_accepted" | "appeal_rejected"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// 削除への異議申立（本人1回のみ・判断は必ず人間）
model Appeal {
  id         String    @id @default(cuid())
  commentId  String    @unique
  userId     String
  reason     String
  status     String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vote {
  id        String     @id @default(cuid())
  userId    String
  issueId   String
  choice    VoteChoice
  createdAt DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([issueId])
}

enum VotePhase {
  BEFORE_READ
  AFTER_READ
}

// 「意見が変わった率」「沈黙の多数派ヒートマップ」用の読前/読後スナップショット。
// 既存Vote（現在の投票状態・投票ゲート・集計の真実のソース）とは別の追記用テーブルにして、
// 既存の投票ロジック・投票ゲートに影響を与えない。
// BEFORE_READはcastVote()が初回投票時に自動記録。AFTER_READは読了ゲート後の連続スライダー投票専用。
model VoteEvent {
  id     String     @id @default(cuid())
  userId String
  issueId String
  phase  VotePhase
  // BEFORE_READ: 3択投票と同じ値。AFTER_READ: intensityから導出したbucket（互換的な扱い用）
  choice VoteChoice
  // AFTER_READ（連続スライダー）のときだけ値が入る。-100=強く反対 〜 +100=強く賛成
  intensity Int?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId, phase])
  @@index([issueId, phase])
}

model Comment {
  id               String           @id @default(cuid())
  issueId          String
  userId           String
  stance           VoteChoice
  body             String
  likeCount        Int              @default(0)
  dislikeCount     Int              @default(0)
  helpfulCount     Int              @default(0)
  isHidden         Boolean          @default(false) // 表示可否（moderationStatusから導出・クエリ用）
  moderationStatus ModerationStatus @default(VISIBLE)
  // 返信スレッド（1階層のみ、返信への返信は無し）。トップレベルコメントはnull
  parentId         String?
  replyCount       Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue    Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  parent   Comment?         @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]        @relation("CommentReplies")
  fcCache  FcCache?
  reports  Report[]
  helpfuls Helpful[]
  cases    ModerationCase[]
  appeal   Appeal?

  @@index([issueId, createdAt])
  @@index([parentId, createdAt])
}

model Helpful {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  // commentId起点の集計(越境評価スコア計算)に必要。@@unique([userId,commentId])はuserId先頭のため使えない
  @@index([commentId])
}

// 「保存したスレッド」。ユーザーが後で読み返すために争点をブックマークする。
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  issueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([userId, createdAt])
}

/** 政治家・政党の争点での立場。VoteChoiceを流用しないのは「棄権」が実在するため（国会採決は賛成/反対/棄権が実データにある） */
enum PoliticianStance {
  FOR
  AGAINST
  ABSTAIN
}

/** 政治家・政党。争点横断で「中立層への説得力」を集計する対象（IssuePolitician経由） */
model Politician {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  /** 所属政党（政党そのものをエントリにする場合はnullで可） */
  party     String?
  createdAt DateTime @default(now())

  issues IssuePolitician[]

  @@index([name])
}

/**
 * 争点と政治家/政党の紐付け。stanceはその争点でこの政治家/政党がどちら側の立場を取ったか。
 * 法案系争点はdietVote（本会議の記名投票結果）から自動タグ付けできる
 * （tagPoliticiansFromDietVote、src/lib/politician-tagging.ts）。
 * この行を起点に、該当stance側のコメントの越境評価(bridging)を集計して説得力スコアを出す
 * （ABSTAINはComment.stance側に対応する陣営が無いため集計対象外）。
 */
model IssuePolitician {
  id           String           @id @default(cuid())
  issueId      String
  politicianId String
  stance       PoliticianStance
  /** dietVote由来か等の出典メモ（任意） */
  source       String?
  createdAt    DateTime         @default(now())

  issue      Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  politician Politician @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@unique([issueId, politicianId])
  @@index([politicianId])
}

model FcCache {
  id         String    @id @default(cuid())
  commentId  String    @unique
  verdict    FcVerdict
  label      String? // 表示用ラベル（「条文上確認」「報道ベース」等の細分類）
  reason     String
  sourceIds  String[]
  sourceUrls Json? // [{"label","url"}] 出典リンク（必ず表示する要件）
  resultJson Json
  createdAt  DateTime  @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

enum EvidenceSourceType {
  LAW // e-Gov 法令
  DIET_RECORD // 国会会議録
  TREATY // 条約・国際文書
  HISTORICAL_DOC // 歴史文書（ポツダム宣言、日本国憲法制定経緯 等）
  COURT_RULING // 判例（型のみ用意。判例DBは次フェーズで投入）
}

// ファクトチェックの根拠チャンク（法令・国会発言・条約・歴史文書を汎用的に保持）
model EvidenceChunk {
  id         String                       @id @default(cuid())
  sourceType EvidenceSourceType
  sourceId   String // 法令ID/会議録検索キーワードID/条約名スラッグ等
  sourceName String // 表示名「消費税法」「第213回国会 予算委員会」「日本国憲法」
  articleRef String?
  text       String
  sourceUrl  String
  category   IssueCategory[] // グローバル検索時のブースト用（Issue.categoryと同じ値域）
  keywords   String[] // 検索補助・自動リンクの手がかり
  isActive   Boolean                      @default(true)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  issueLinks IssueEvidenceLink[]

  @@index([sourceType])
  @@index([sourceId])
}

// 争点⇔証拠チャンクの紐付け。pinned=trueは人間/自動が明示的に選んだ優先リンク
// （存在しなくてもEvidenceChunkはグローバル検索の対象になる＝必須ではない）
model IssueEvidenceLink {
  id      String  @id @default(cuid())
  issueId String
  chunkId String
  pinned  Boolean @default(false)

  issue Issue         @relation(fields: [issueId], references: [id], onDelete: Cascade)
  chunk EvidenceChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([issueId, chunkId])
}

// 数値主張の裏取り用データ（GDP・失業率・税収等）。スキーマのみ用意し、
// e-Stat/日銀時系列からの自動取り込みと数値ファクトチェック機能は次フェーズで実装。
model StatisticSeries {
  id         String   @id @default(cuid())
  seriesId   String   @unique
  name       String
  unit       String
  sourceName String
  sourceUrl  String
  updatedAt  DateTime @updatedAt

  points StatisticPoint[]
}

model StatisticPoint {
  id          String @id @default(cuid())
  seriesId    String
  periodLabel String // "2026Q1", "2026-06" 等
  value       Float

  series StatisticSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, periodLabel])
}

model UserBadge {
  id           String        @id @default(cuid())
  userId       String
  category     IssueCategory
  tier         String
  helpfulCount Int           @default(0)
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Report {
  id         String   @id @default(cuid())
  commentId  String
  reporterId String
  reason     String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}
