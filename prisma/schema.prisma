generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum Plan {
  FREE
  COMMENT
  FACTCHECK
}

enum VoteChoice {
  FOR
  AGAINST
  UNDECIDED
}

enum IssueStatus {
  ACTIVE
  TRENDING
  PASSED
  ARCHIVED
}

enum IssueCategory {
  POLITICS
  LAW
  ECONOMY
  FINANCE
  EDUCATION
}

enum FcVerdict {
  TRUE // дёҖж¬Ўжғ…е ұгҒ§зўәиӘҚгҒ§гҒҚгҒҹ
  FALSE // дёҖж¬Ўжғ…е ұгҒЁзҹӣзӣҫ
  UNKNOWN // дёҖж¬Ўжғ…е ұгҒ§гҒҜзўәиӘҚдёҚеҸҜ
  OPINION // ж„ҸиҰӢгғ»и©•дҫЎ
  REPORTED // е ұйҒ“гҒ®еӯҳеңЁгҒҜзўәиӘҚгғ»еҶ…е®№гҒ®зңҹеҒҪгҒҜжңӘзўәиӘҚ
  DISPUTED // еҪ“дәӢиҖ…й–“гҒ§дё»ејөгҒҢеҜҫз«Ӣ / и§ЈйҮҲгҒҢеҲҶгҒӢгӮҢгӮӢ
}

enum ModerationStatus {
  VISIBLE // йҖҡеёёиЎЁзӨә
  AUTO_HIDDEN // йҖҡе ұй–ҫеҖӨеҲ°йҒ”гҒ§дёҖжҷӮйқһиЎЁзӨәпјҲAIеҲӨе®ҡеҫ…гҒЎпјү
  AI_CLEARED // AIгҒҢе•ҸйЎҢгҒӘгҒ—гҒЁеҲӨе®ҡгҒ—еҫ©её°пјҲеҶҚеәҰгҒ®иҮӘеӢ•йқһиЎЁзӨәгҒҜгҒ—гҒӘгҒ„пјү
  REMOVED_AI // AIгҒҢйҒ•еҸҚгҒЁй«ҳзўәеәҰеҲӨе®ҡпјҲз•°иӯ°з”із«ӢеҸҜпјү
  REMOVED_HUMAN // дәәй–“гҒҢеүҠйҷӨзўәе®ҡ
  HUMAN_REVIEW // AIгҒҢеҲӨе®ҡгӮ’дҝқз•ҷгҒ—дәәй–“гӮӯгғҘгғјиЎҢгҒҚпјҲйқһиЎЁзӨәгҒ®гҒҫгҒҫпјү
}

enum RadarStatus {
  PENDING // жӨңзҹҘзӣҙеҫҢ
  PUBLISHED // иҮӘеӢ•е…¬й–ӢжёҲгҒҝ
  HELD // е®үе…ЁгӮІгғјгғҲгҒ§дёӢжӣёгҒҚжӯўгӮҒпјҲдәәй–“зўәиӘҚеҝ…й Ҳпјү
  REJECTED // гӮ№гӮігӮўдёҚи¶ігҒ§иҰӢйҖҒгӮҠ
}

enum ConfirmationStatus {
  OFFICIAL // е…¬ејҸзҷәиЎЁгғ»жі•жЎҲгғ»еҲӨжұәгғ»зөұиЁҲгғҷгғјгӮ№
  REPORTED // е ұйҒ“гғҷгғјгӮ№ / зңҹеҒҪжңӘзўәиӘҚ
  MANUAL // жүӢеӢ•дҪңжҲҗпјҲеҫ“жқҘгҒ®жі•д»ӨдәүзӮ№пјү
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  // и»ҪйҮҸгғ—гғӯгғ•гӮЈгғјгғ«: дёҖиЁҖиҮӘе·ұзҙ№д»Ӣгғ»зөөж–Үеӯ—гӮўгғҗгӮҝгғјпјҲз”»еғҸгӮўгғғгғ—гғӯгғјгғүгҒҜдёҚиҰҒгҒӘиЁӯиЁҲпјү
  bio                  String?
  avatarEmoji          String?
  plan                 Plan      @default(FREE)
  planUntil            DateTime?
  // Stripe: дәҢйҮҚиӘІйҮ‘йҳІжӯўгғ»и§Јзҙ„е°Һз·ҡгғ»webhookгҒ®гғҰгғјгӮ¶гғји§ЈжұәгҒ«еҝ…й Ҳ
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  // ж–°иҰҸзҷ»йҢІжҷӮгҒ®IP/еӣҪпјҲ90ж—Ҙ1IP1гӮўгӮ«гӮҰгғігғҲгғ»дёҚжӯЈжҠ•зҘЁеҜҫзӯ–пјү
  registrationIp       String?
  registrationCountry  String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  votes     Vote[]
  comments  Comment[]
  badges    UserBadge[]
  reports   Report[]
  bookmarks Bookmark[]

  @@index([registrationIp, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Issue {
  id                 String        @id @default(cuid())
  slug               String        @unique
  title              String
  category           IssueCategory
  status             IssueStatus   @default(ACTIVE)
  summaryJson        Json
  articleHtml        String?
  articleGeneratedAt DateTime?
  monitoringUntil    DateTime?
  keywords           String[]
  // йқһжӯЈиҰҸеҢ–гӮ«гӮҰгғігӮҝ: RedisгҒҢзңҹе®ҹгҒ®гӮҪгғјгӮ№гҖҒDBгҒҜйқһеҗҢжңҹиҝҪеҫ“пјҲдёҖиҰ§гғ»SEOгғҡгғјгӮёз”Ёпјү
  voteForCount       Int           @default(0)
  voteAgainstCount   Int           @default(0)
  voteUndecidedCount Int           @default(0)
  commentCount       Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Radarз”ұжқҘгҒ®дәүзӮ№з”ЁгғЎгӮҝгғҮгғјгӮҝ
  confirmation   ConfirmationStatus   @default(MANUAL)
  voteLabelsJson Json? // жҠ•зҘЁгғңгӮҝгғігҒ®гӮ«гӮ№гӮҝгғ ж–ҮиЁҖ {"for":"иӘ¬жҳҺгҒҷгҒ№гҒҚ","against":"е•ҸйЎҢгҒӘгҒ„","undecided":"еҲӨж–ӯгҒ§гҒҚгҒӘгҒ„"}
  // е…¬й–ӢеҫҢгҒ®е“ҒиіӘе ұе‘ҠпјҲиӘӨгҒЈгҒҹиҰҒзҙ„гғ»зҡ„еӨ–гӮҢгҒӘгӮ№гғ¬з«ӢгҒҰзӯүпјүгҒҢй–ҫеҖӨгҒ«йҒ”гҒҷгӮӢгҒЁ trueгҖӮ
  // дәәй–“зўәиӘҚгҒҢзөӮгӮҸгӮӢгҒҫгҒ§гғҲгғ¬гғігғүиЎЁзӨәгғ»ж–°иҰҸжөҒе…ҘгҒӢгӮүеӨ–гҒҷпјҲеүҠйҷӨгҒҜгҒ—гҒӘгҒ„пјқйҖҸжҳҺжҖ§гғӯгӮ°гҒЁгҒ—гҒҰж®ӢгҒҷпјү
  underReview    Boolean              @default(false)
  qualityReports IssueQualityReport[]

  votes     Vote[]
  comments  Comment[]
  lawLinks  IssueLawLink[]
  timeline  IssueTimeline[]
  bookmarks Bookmark[]
}

// гҖҢгҒ“гҒ®иҰҒзҙ„гҒҜгҒҠгҒӢгҒ—гҒ„гҖҚе ұе‘ҠпјҲRadarиҮӘеӢ•з”ҹжҲҗдәүзӮ№еҗ‘гҒ‘пјүгҖӮй–ҫеҖӨеҲ°йҒ”гҒ§underReviewеҢ–гҖӮ
model IssueQualityReport {
  id         String   @id @default(cuid())
  issueId    String
  reporterId String
  reason     String?
  createdAt  DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, reporterId])
}

// RadarгҒҢжӨңзҹҘгҒ—гҒҹз”ҹгӮ·гӮ°гғҠгғ«пјҲ30ж—ҘгҒ§гӮҜгғӘгғјгғігӮўгғғгғ—гғ»Layer 2пјү
model SourceEvent {
  id          String   @id @default(cuid())
  feedName    String
  trustWeight Int // гғ•гӮЈгғјгғүдҝЎй јеәҰ 20-100
  title       String
  url         String
  publishedAt DateTime
  hash        String   @unique // feedName+titleгҒ®sha256пјҲйҮҚиӨҮеҸ–гӮҠиҫјгҒҝйҳІжӯўпјү
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// RadarгҒ®гғҲгғ”гғғгӮҜеҖҷиЈңгҒЁе…¬й–ӢеҲӨж–ӯгғӯгӮ°пјҲйҖҸжҳҺжҖ§гғ¬гғқгғјгғҲгҒ®жқҗж–ҷгғ»й•·жңҹдҝқеӯҳпјү
model TopicCandidate {
  id             String      @id @default(cuid())
  dedupKey       String      @unique // жӯЈиҰҸеҢ–гӮҝгӮӨгғҲгғ«пјҲеҗҢдёҖгғҲгғ”гғғгӮҜгҒ®еҶҚжӨңзҹҘйҳІжӯўпјү
  title          String
  category       String? // politics/economy/law/finance/rights/international
  classification String? // official/report/scandal/incident/indicator
  eventCount     Int         @default(0)
  distinctFeeds  Int         @default(0)
  hotScore       Int         @default(0)
  trustScore     Int         @default(0)
  riskScore      Int         @default(0)
  riskFlags      String[] // жӨңеҮәгҒ•гӮҢгҒҹеҚұйҷәгӮ·гӮ°гғҠгғ«
  decision       String? // еҲӨж–ӯејҸгҒ®еҶ…иЁіпјҲзӣЈжҹ»з”Ёпјү
  status         RadarStatus @default(PENDING)
  sourceUrls     Json // [{"title","url","feed"}]
  issueId        String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, createdAt])
}

// дәүзӮ№гҒ®жҷӮзі»еҲ—жӣҙж–°пјҲз¶ҡе ұгғ»жң¬дәәеҸҚеҝңгғ»иЁӮжӯЈпјү
model IssueTimeline {
  id        String   @id @default(cuid())
  issueId   String
  label     String // гҖҢйҖҹе ұгӮ№гғ¬е…¬й–ӢгҖҚгҖҢSonnetгҒҫгҒЁгӮҒе…¬й–ӢгҖҚгҖҢжң¬дәәгҒҢеҗҰе®ҡгӮ’иЎЁжҳҺгҖҚзӯү
  sourceUrl String?
  at        DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, at])
}

// гғўгғҮгғ¬гғјгӮ·гғ§гғідәәй–“гӮӯгғҘгғјпјҲAIгҒҢеҲӨе®ҡдҝқз•ҷгҒ—гҒҹ1еүІ + з•°иӯ°з”із«Ӣпјү
model ModerationCase {
  id         String    @id @default(cuid())
  commentId  String
  source     String // "reports"(йҖҡе ұиө·зӮ№) | "appeal"(з•°иӯ°з”із«Ӣ)
  aiVerdict  Json? // nanoгҒ®еҲӨе®ҡеҶ…е®№пјҲдәәй–“гҒ®еҸӮиҖғжғ…е ұпјү
  status     String    @default("PENDING") // PENDING | RESOLVED
  resolution String? // "removed" | "restored" | "appeal_accepted" | "appeal_rejected"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// еүҠйҷӨгҒёгҒ®з•°иӯ°з”із«ӢпјҲжң¬дәә1еӣһгҒ®гҒҝгғ»еҲӨж–ӯгҒҜеҝ…гҒҡдәәй–“пјү
model Appeal {
  id         String    @id @default(cuid())
  commentId  String    @unique
  userId     String
  reason     String
  status     String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Vote {
  id        String     @id @default(cuid())
  userId    String
  issueId   String
  choice    VoteChoice
  createdAt DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([issueId])
}

model Comment {
  id               String           @id @default(cuid())
  issueId          String
  userId           String
  stance           VoteChoice
  body             String
  likeCount        Int              @default(0)
  dislikeCount     Int              @default(0)
  helpfulCount     Int              @default(0)
  isHidden         Boolean          @default(false) // иЎЁзӨәеҸҜеҗҰпјҲmoderationStatusгҒӢгӮүе°ҺеҮәгғ»гӮҜгӮЁгғӘз”Ёпјү
  moderationStatus ModerationStatus @default(VISIBLE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue    Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  fcCache  FcCache?
  reports  Report[]
  helpfuls Helpful[]
  cases    ModerationCase[]
  appeal   Appeal?

  @@index([issueId, createdAt])
}

model Helpful {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// гҖҢдҝқеӯҳгҒ—гҒҹгӮ№гғ¬гғғгғүгҖҚгҖӮгғҰгғјгӮ¶гғјгҒҢеҫҢгҒ§иӘӯгҒҝиҝ”гҒҷгҒҹгӮҒгҒ«дәүзӮ№гӮ’гғ–гғғгӮҜгғһгғјгӮҜгҒҷгӮӢгҖӮ
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  issueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([userId, createdAt])
}

model FcCache {
  id         String    @id @default(cuid())
  commentId  String    @unique
  verdict    FcVerdict
  label      String? // иЎЁзӨәз”Ёгғ©гғҷгғ«пјҲгҖҢжқЎж–ҮдёҠзўәиӘҚгҖҚгҖҢе ұйҒ“гғҷгғјгӮ№гҖҚзӯүгҒ®зҙ°еҲҶйЎһпјү
  reason     String
  sourceIds  String[]
  sourceUrls Json? // [{"label","url"}] еҮәе…ёгғӘгғігӮҜпјҲеҝ…гҒҡиЎЁзӨәгҒҷгӮӢиҰҒд»¶пјү
  resultJson Json
  createdAt  DateTime  @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model LawChunk {
  id         String                       @id @default(cuid())
  lawId      String
  lawName    String
  articleRef String?
  text       String
  sourceUrl  String
  isActive   Boolean                      @default(true)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  issueLinks IssueLawLink[]

  @@index([lawId])
}

model IssueLawLink {
  id         String @id @default(cuid())
  issueId    String
  lawChunkId String

  issue    Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  lawChunk LawChunk @relation(fields: [lawChunkId], references: [id], onDelete: Cascade)

  @@unique([issueId, lawChunkId])
}

model UserBadge {
  id           String        @id @default(cuid())
  userId       String
  category     IssueCategory
  tier         String
  helpfulCount Int           @default(0)
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Report {
  id         String   @id @default(cuid())
  commentId  String
  reporterId String
  reason     String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

model ContentCache {
  id        String   @id @default(cuid())
  key       String   @unique
  type      String
  content   Json
  createdAt DateTime @default(now())
}
