{
  "name": "japan-politics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "prebuild": "PRISMA_CLIENT_FORCE_WASM=1 prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "article": "tsx scripts/generate-article.ts",
    "check-env": "tsx scripts/check-env.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts",
    "seed:buzz": "tsx scripts/seed-production-buzz.ts",
    "radar:inspect": "tsx scripts/radar/inspect-pipeline.ts",
    "radar:diagnose-buzz": "tsx scripts/radar/diagnose-buzz.ts",
    "db:generate": "prisma generate",
    "db:push": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; exec prisma db push'",
    "db:studio": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; exec prisma studio'",
    "postopennextbuild": "node scripts/patch-prisma-wasm.mjs",
    "opennextbuild": "rm -rf .next .open-next && opennextjs-cloudflare build",
    "preview": "npm run opennextbuild && opennextjs-cloudflare preview",
    "deploy": "npm run opennextbuild && OPEN_NEXT_DEPLOY=true wrangler deploy",
    "upload": "npm run opennextbuild && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@auth/prisma-adapter": "^2.9.1",
    "@google/genai": "^2.12.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.9.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^15.3.4",
    "next-auth": "^5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanitize-html": "^2.17.5",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.3.1",
    "unpdf": "^1.6.2",
    "web-push": "^3.6.7",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
