# Cloudflare Worker secrets（wrangler secret bulk 用）
# 使い方: cp .env.local scripts/cf-secrets.env && 下記以外を削除してから
#   npx wrangler secret bulk scripts/cf-secrets.env
AUTH_SECRET=
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
DATABASE_URL=
DIRECT_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COMMENT=
STRIPE_PRICE_FACTCHECK=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# discover 争点選別（Azure Foundry のデプロイ名。例: gpt-5-mini）
RADAR_TOPIC_FILTER_MODEL=
# detect RSS/LIVE クラスタリング（nano のまま）
RADAR_CLASSIFY_MODEL=
YOUTUBE_DATA_API_KEY=
RADAR_INTERNAL_SECRET=
ADMIN_EMAILS=
EMAIL_FROM=
RESEND_API_KEY=
